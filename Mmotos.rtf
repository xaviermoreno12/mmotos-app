CREATE TYPE estado_fiscal_enum AS ENUM ('PENDIENTE', 'APROBADO', 'ERROR_HARDWARE', 'CONTINGENCIA');\par
CREATE TYPE sync_status_enum AS ENUM ('LOCAL', 'SYNCED', 'CONFLICT');\par
\par
-- 2. Tabla de Productos con Atributos Din\'e1micos\par
